# Config for stock Wanhao Duplicator 12/300, with MKS Robin Nano V1.2
# STM32F103 @ 8MHz ; 28KiB Bootloader Offset ; Communication Interface on Serial (on USART3 PB11/PB10)
# Based on : https://github.com/Yumi-Lab/yumi-config/tree/main/smartpad-wanhao-D12300-DUAL-MKS1.2-3TMC-2A4988-BL

[printer]
kinematics: cartesian
max_velocity: 250
max_accel: 2500
max_z_velocity: 25
max_z_accel: 100

[stepper_x]
step_pin: PE3
dir_pin: PE2
enable_pin: !PE4
microsteps: 16
rotation_distance: 40
endstop_pin: !PA15
position_endstop: 0
position_max: 350
homing_speed: 40

[stepper_y]
step_pin: PE0
dir_pin: !PB9
enable_pin: !PE1
microsteps: 16
rotation_distance: 40
endstop_pin: !PA12
position_endstop: 0
position_max: 310
homing_speed: 40

[stepper_z]
step_pin: PB5
dir_pin: PB4  #!PB4 pour A4988 et PB4 pour TMC2209
enable_pin: !PB8
microsteps: 16
rotation_distance: 8
endstop_pin: !PA11  # Uncomment if NO BLtouch used
#endstop_pin:probe:z_virtual_endstop # Comment if NO BLTouch used
position_endstop: 0 # Uncomment if NO BLtouch used
position_max: 400
position_min: -2

[safe_z_home]
home_xy_position: 145,115
speed: 80.0
z_hop: 10.0
z_hop_speed: 10.0

[extruder]
step_pin: PD6
dir_pin: !PD3
enable_pin: !PB3
microsteps: 16
rotation_distance: 22.6789511
gear_ratio: 3:1    #TITAN Gear Ratio 3:1 ,  BMG Raatio 50:17
full_steps_per_rotation: 200 #200 for 1.8 degree, 400 for 0.9 degree
nozzle_diameter: 0.400
filament_diameter: 1.750
heater_pin: PC3
sensor_type: ATC Semitec 104GT-2
sensor_pin: PC1
min_temp: 0
max_temp: 250
max_extrude_only_velocity: 60
max_extrude_only_distance: 500
max_extrude_cross_section: 100
pressure_advance: 0.35

[extruder_stepper extruder1] #T1
extruder: 
step_pin: PA6
dir_pin: !PA1
enable_pin: !PA3
full_steps_per_rotation: 200
microsteps: 16
rotation_distance: 7.952

